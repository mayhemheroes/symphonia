# .dockerignore for the commit-image build.
# Bake in the FULL repo (including .git history — the grader/PATCH tier use it), dropping only
# local build artifacts and editor/OS cruft. Dev image, not minimal.

# ── Build outputs / local cruft ──────────────────────────────────────────────
/target/
mayhem/fuzz/target/
symphonia/fuzz/target/
*.o
*.a
*.so
*.dylib
**/__pycache__/

# ── Editor / OS noise ────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
